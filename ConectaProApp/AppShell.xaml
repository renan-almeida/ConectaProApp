<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="ConectaProApp.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:ConectaProApp"
    xmlns:usuario="clr-namespace:ConectaProApp.View.Usuario"
    xmlns:popup="clr-namespace:ConectaProApp.View.PopUp"
    Shell.FlyoutBehavior="Flyout"
    Title="ConectaProApp">

    <ShellContent
        Title="Home"
        ContentTemplate="{DataTemplate local:MainPage}"
        Route="MainPage" />

    <ShellContent Route="login" 
                  ContentTemplate="{DataTemplate usuario:LoginView}"
                  />

    <ShellContent Route="tipoConta" 
                  ContentTemplate="{DataTemplate popup:TipoContaPopUp}"
                  />

    <!--
    <ShellContent Route="RegistroCliente"
                  ContentTemplate="{DataTemplate local:LoginView}"
    />
    <ShellContent Route="RegistroPrestador"
                  ContentTemplate="{DataTemplate local:LoginView}"
    />
    -->

</Shell>