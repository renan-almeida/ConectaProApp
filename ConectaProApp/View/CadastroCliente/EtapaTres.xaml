<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ConectaProApp.View.CadastroCliente.EtapaTres"
             Title="EtapaTres">
    <ScrollView>
        <VerticalStackLayout
        Padding="30,0"
        Spacing="25">

             <Image
            Source="conectapro_logo.png"
            HeightRequest="100"
            Aspect="AspectFit"
            HorizontalOptions="Center" />
            

            <Label
            Text="3. Estamos quase lá"
            FontSize="24"
            HorizontalOptions="Center" />

            <Label
            Text="Insira as últimas informações e ingresse na ConectaPro!."
            FontSize="14"
            HorizontalOptions="Center" />

            <Entry
            Placeholder="Telefone"
            FontSize="18"
            HorizontalOptions="Fill" />

            <Entry
            Placeholder="CEP"
            FontSize="18"
            HorizontalOptions="Fill" />

            <Entry
            Placeholder="Nro"
            FontSize="18"
            HorizontalOptions="Fill" />

            <Button
            Text="Próximo"
            FontSize="18"
            BackgroundColor="Blue"
            TextColor="White"
            HorizontalOptions="Fill"
            Clicked="OnNextButtonClicked" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>