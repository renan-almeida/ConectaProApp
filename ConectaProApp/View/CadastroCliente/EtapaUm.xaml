<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ConectaProApp.View.CadastroCliente.EtapaUm"
             Title="EtapaUm">
    <ScrollView>
        <VerticalStackLayout
         Padding="30,0"
         Spacing="25">


             
            <Image
             Source="logo.png"
             HeightRequest="100"
             Aspect="AspectFit"
             HorizontalOptions="Center" />
            

            <Label
             Text="1. Informações pessoais"
             FontSize="24"
             HorizontalOptions="Center" />

            <Label
             Text="Como proprietário do seu negócio, insira suas informações pessoais."
             FontSize="14"
             HorizontalOptions="Center" />

            <Entry
             Placeholder="Digite o seu Nome"
             FontSize="18"
             HorizontalOptions="Fill" />

            <Entry
             Placeholder="Digite seu Email"
             FontSize="18"
             HorizontalOptions="Fill" />

            <Button
             Text="Próximo"
             FontSize="18"
             BackgroundColor="Blue"
             TextColor="White"
             HorizontalOptions="Fill"
             Clicked="OnNextButtonClicked" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>