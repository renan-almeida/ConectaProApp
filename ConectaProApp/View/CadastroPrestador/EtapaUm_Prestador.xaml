<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ConectaProApp.View.CadastroPrestador.EtapaUm_Prestador"
             Title="EtapaUm_Prestador">
    <StackLayout Padding="20">
        <Image Source="conectapro_logo.png" HorizontalOptions="Center" /> 
        <Label Text="1. Informações pessoais" FontSize="Large" HorizontalOptions="Center" />
        <Entry Placeholder="Digite o seu Nome" />
        <Entry Placeholder="Digite seu Email" />
        <Entry Placeholder="Digite seu telefone" />
        <Button Text="Proximo" Clicked="OnNextButtonClicked" />
    </StackLayout>
</ContentPage>